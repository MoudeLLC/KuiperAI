  "response_templates": {
    "profanity_detected": "I notice some strong language in your message. I'm here to help in a respectful way. Could you rephrase that?",
    "harmful_content": "I can't help with that request as it could be harmful. Is there something else I can assist you with?",
    "respectful_decline": "I'd prefer to keep our conversation respectful. How else can I help you today?",
    "violence_detected": "I can't provide information about violence or harm. If you're in crisis, please contact emergency services or a crisis helpline.",
    "illegal_activity": "I can't assist with illegal activities. I'm here to help with legal and constructive questions.",
    "sexual_content": "I'm not designed to discuss explicit sexual content. I can help with other topics though.",
    "self_harm_detected": "I'm concerned about what you've shared. Please reach out to a crisis helpline: National Suicide Prevention Lifeline: 988 or 1-800-273-8255. I'm here if you want to talk about something else.",
    "hate_speech": "I don't engage with hate speech or discriminatory content. Let's keep our conversation respectful and constructive.",
    "child_safety": "I cannot and will not engage with content involving minors in inappropriate contexts. This conversation ends here."
  },
  
  "immediate_stop_triggers": {
    "description": "These trigger immediate conversation termination",
    "enabled": true,
    "triggers": [
      "child exploitation",
      "child abuse",
      "child pornography",
      "underage sexual",
      "minor sexual",
      "pedophilia",
      "how to harm children",
      "how to abuse",
      "suicide methods",
      "how to kill myself",
      "painless suicide",
      "how to make bomb",
      "how to build weapon",
      "terrorist attack planning",
      "mass shooting",
      "school shooting"
    ],
    "response": "I cannot continue this conversation. If you're in crisis, please contact emergency services immediately."
  },
  
  "training_filters": {
    "remove_documents_containing": {
      "enabled": true,
      "min_profanity_count": 3,
      "description": "Remove training documents with 3+ profane words"
    },
    "replace_profanity": {
      "enabled": false,
      "replacement": "[FILTERED]",
      "description": "Replace profanity with placeholder instead of removing"
    },
    "skip_short_toxic_docs": {
      "enabled": true,
      "max_length": 200,
      "description": "Skip short documents that are mostly toxic"
    }
  },
  
  "inference_behavior": {
    "detect_user_profanity": {
      "enabled": true,
      "action": "polite_reminder",
      "description": "Gently remind user to be respectful"
    },
    "never_generate_profanity": {
      "enabled": true,
      "description": "AI never uses profanity in responses"
    },
    "educational_context": {
      "enabled": true,
      "description": "Allow discussing profanity in educational context (e.g., 'What does X word mean?')"
    }
  }
